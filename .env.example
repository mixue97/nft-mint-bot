# =============================================================================
# NFT Mint Bot - environment variables
# Copy this file to `.env` and fill in your own values.
# NEVER commit `.env` with a real PRIVATE_KEY.
# =============================================================================

# ---- Wallet ----------------------------------------------------------------
# Hot wallet private key (0x-prefixed). Use a fresh wallet that only holds
# enough native token for gas + mint price. Sweep NFTs to a cold wallet
# immediately after mint succeeds.
PRIVATE_KEY=0xyour_private_key_here

# ---- Chain -----------------------------------------------------------------
# Currently supported: mainnet, sepolia, base, arbitrum, optimism, polygon, bsc
CHAIN=mainnet

# ---- RPC endpoints ---------------------------------------------------------
# Comma-separated list of HTTP RPC URLs. The bot will race them in parallel
# and use the fastest response. Use paid, low-latency endpoints.
RPC_URLS=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY,https://mainnet.infura.io/v3/YOUR_KEY

# Optional WebSocket endpoint for `newHeads` subscription (recommended).
WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ---- Flashbots / private mempool -------------------------------------------
# Modes:
#   protect  -> use Flashbots Protect RPC for a single private tx (simpler)
#   bundle   -> submit eth_sendBundle bundles to a relay (advanced)
#   public   -> public mempool (NOT recommended for FCFS mints)
PRIVATE_TX_MODE=protect

# Used in `bundle` mode. Default is the public Flashbots relay.
FLASHBOTS_RELAY=https://relay.flashbots.net

# Used in `protect` mode. `fast` enables MEV-Share fast mode.
FLASHBOTS_PROTECT_RPC=https://rpc.flashbots.net/fast

# ---- Mint target -----------------------------------------------------------
# NFT contract address.
NFT_CONTRACT=0x0000000000000000000000000000000000000000

# Mint function name (e.g. mint, publicMint, claim).
MINT_FUNCTION=mint

# JSON-encoded array of arguments to pass to the mint function.
# Example for `mint(uint256 quantity)`:    [1]
# Example for `mintWithProof(bytes32[] proof, uint256 qty)`:
#   [["0xabc...","0xdef..."], 1]
MINT_ARGS=[1]

# Native token sent with the mint call, in wei. e.g. 0.05 ETH = 50000000000000000.
MINT_VALUE_WEI=0

# Override gas limit. If 0 the bot will simulate first and add a 20 % buffer.
GAS_LIMIT=0

# Override calldata. If set, MINT_FUNCTION/MINT_ARGS/ABI are ignored and this
# raw HEX is used as `data`. Useful for unverified contracts (capture HEX from
# the wallet popup using the Time Traveller trick).
RAW_CALLDATA=

# ---- Timing ----------------------------------------------------------------
# Unix epoch seconds when the mint opens.
MINT_TIMESTAMP=0

# Fire the bundle this many milliseconds before MINT_TIMESTAMP. Tune by RTT.
LEAD_TIME_MS=400

# ---- Gas strategy ----------------------------------------------------------
# Maximum total fee per gas you are willing to pay (gwei). Hard cap.
MAX_FEE_PER_GAS_GWEI=50

# Priority tip per gas (gwei). The bot will also send fan-out tx at higher
# tips - see TIP_LADDER_GWEI.
PRIORITY_FEE_GWEI=5

# Comma-separated tip ladder (gwei). One tx per nonce, ascending tips.
# Set to a single value to send only one tx.
TIP_LADDER_GWEI=5,15,30

# ---- Safety ----------------------------------------------------------------
# Refuse to broadcast if simulation reverts. Set to 0 only for unverified
# contracts where simulation is impossible.
REQUIRE_SIM=1

# Max blocks to keep retrying if the first bundle is dropped.
MAX_RETRY_BLOCKS=3
