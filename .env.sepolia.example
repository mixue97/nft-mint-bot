# =============================================================================
# Sepolia rehearsal preset.
# Copy to `.env` (overwrite the default), fill PRIVATE_KEY + RPC_URLS, then
# follow REHEARSAL.md.
# =============================================================================

# ---- Wallet ----------------------------------------------------------------
# A throw-away Sepolia wallet. Fund it with ~0.1 testnet ETH from
# https://sepoliafaucet.com or https://www.alchemy.com/faucets/ethereum-sepolia
PRIVATE_KEY=0xyour_sepolia_private_key

# ---- Chain -----------------------------------------------------------------
CHAIN=sepolia

# ---- RPC -------------------------------------------------------------------
# Free endpoints work fine for testnet, but a paid one (Alchemy / QuickNode)
# is closer to your real-money setup.
RPC_URLS=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY,https://ethereum-sepolia-rpc.publicnode.com
WS_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ---- Mock contract args (used by `npm run deploy-mock`) --------------------
MOCK_NAME=RehearsalNFT
MOCK_SYMBOL=REHRSE
MOCK_MAX_SUPPLY=100
MOCK_MINT_PRICE_WEI=10000000000000000   # 0.01 sETH per token
MOCK_MAX_PER_WALLET=5
# MOCK_MINT_START defaults to (now + 5 minutes) if unset.
# MOCK_MINT_START=1716471600

# ---- Bot target (fill AFTER `npm run deploy-mock` prints the address) ------
NFT_CONTRACT=0x0000000000000000000000000000000000000000
MINT_FUNCTION=mint
MINT_ARGS=[1]
MINT_VALUE_WEI=10000000000000000
GAS_LIMIT=0
RAW_CALLDATA=

MINT_TIMESTAMP=0          # paste from deploy-mock output
LEAD_TIME_MS=400

# ---- Gas strategy ----------------------------------------------------------
MAX_FEE_PER_GAS_GWEI=20
PRIORITY_FEE_GWEI=2
TIP_LADDER_GWEI=2,5,10

# ---- Private mempool -------------------------------------------------------
# Sepolia does NOT have Flashbots. Use `public` for testnet rehearsal so we
# can actually see the tx land.
PRIVATE_TX_MODE=public
FLASHBOTS_RELAY=https://relay-sepolia.flashbots.net
FLASHBOTS_PROTECT_RPC=https://rpc-sepolia.flashbots.net

# ---- Safety ----------------------------------------------------------------
REQUIRE_SIM=1
MAX_RETRY_BLOCKS=3
