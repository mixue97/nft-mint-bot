{
  "name": "nft-mint-bot",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "simulate": "tsx src/index.ts --dry-run",
    "compile-mock": "tsx scripts/compileMock.ts",
    "deploy-mock": "tsx scripts/deployMock.ts",
    "setup": "bash scripts/setup-vps.sh",
    "run-bot": "bash scripts/run-bot.sh",
    "status": "bash scripts/status.sh",
    "logs": "bash scripts/logs.sh",
    "stop": "bash scripts/stop.sh"
  },
  "author": "",
  "license": "MIT",
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "viem": "^2.48.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@types/node": "^22.19.17",
    "@types/ws": "^8.18.1",
    "solc": "^0.8.35",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
